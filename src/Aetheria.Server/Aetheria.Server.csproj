<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Aetheria.Server</RootNamespace>
    <AssemblyName>Aetheria.Server</AssemblyName>
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <ConcurrentGarbageCollection>false</ConcurrentGarbageCollection>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Aetheria.Shared\Aetheria.Shared.csproj" />
  </ItemGroup>

  <!-- Ship the content JSON next to the server binary so it can be edited without recompiling. -->
  <ItemGroup>
    <None Include="data\**\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
